# ============================================================
# App VPS environment — IAP reference stack (phase 02)
# ============================================================

# Zitadel (auth VPS) — đã deploy ở phase 01
ZITADEL_HOSTNAME=auth.lab.local
ZITADEL_ISSUER_URL=https://auth.lab.local

# ── Next.js demo app ─────────────────────────────────
NEXTJS_HOSTNAME=nextjs-demo.lab.local
NEXTJS_CLIENT_ID=          # từ Zitadel Console → Project internal-apps → App nextjs-demo
NEXTJS_CLIENT_SECRET=      # secret hiện 1 lần khi Auth Method=Basic, copy ngay
# Generate: openssl rand -base64 32 | head -c 32
NEXTJS_COOKIE_SECRET=

# ── Static HTML demo app ─────────────────────────────
STATIC_HOSTNAME=static-demo.lab.local
STATIC_CLIENT_ID=          # từ Zitadel App static-demo
STATIC_CLIENT_SECRET=
STATIC_COOKIE_SECRET=
