# ============================================================
# Auth VPS environment — Zitadel central
# Copy to .env, fill secrets. NEVER commit .env.
# ============================================================

# External domain Zitadel sẽ phục vụ (subdomain công ty)
# Production: auth.<company>.com
# Lab: auth.lab.local (yêu cầu /etc/hosts trên cả VPS + client)
ZITADEL_EXTERNAL_DOMAIN=auth.lab.local

# Masterkey: openssl rand -base64 32 | tr -d '\n' | head -c 32
# LƯU ≥2 NƠI ĐỘC LẬP (Bitwarden + sealed envelope). Mất = mất tất cả encrypted data.
ZITADEL_MASTERKEY=CHANGE_ME_32_CHARS_RANDOM_STRING

# Postgres admin (chỉ dùng cho init/setup) — generate: openssl rand -base64 24
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=CHANGE_ME_postgres_admin

# Postgres least-priv user cho Zitadel runtime
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=CHANGE_ME_zitadel_db

# First admin (đổi password ngay sau login đầu, bind Passkey)
ZITADEL_ADMIN_USERNAME=zitadel-admin
ZITADEL_ADMIN_PASSWORD=CHANGE_ME_admin_init

# Break-glass admin sẽ được tạo qua UI sau khi setup xong (founder/sếp trực tiếp)
# Credential sealed offline, không lưu vào file này.

# ============================================================
# Backup → S3 nội bộ công ty (rclone)
# ============================================================
S3_ENDPOINT=https://s3.internal.company
S3_BUCKET=authway-zitadel-backup
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
BACKUP_RETENTION_DAYS=30

# ============================================================
# Telegram alert (monitoring stack)
# Tạo bot qua @BotFather, group chat → /start bot → chat_id qua https://api.telegram.org/bot<TOKEN>/getUpdates
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# SMTP relay (production)
# Lab: dùng mailhog service trong compose (host=mailhog port=1025 no auth)
# Production: thay bằng SMTP công ty hoặc Mailgun/SES
# Cấu hình SMTP của Zitadel qua admin UI hoặc zitadel-steps.yaml
# ============================================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lab.local
