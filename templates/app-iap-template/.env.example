# Authway App IAP — Environment template
# Copy → .env, fill all 6 vars, then run scripts/gen-secrets.sh để generate COOKIE_SECRET

# ─── App ──────────────────────────────────────────────────────────────
# Public hostname app sẽ phục vụ (phải khớp Redirect URI trong Zitadel app)
APP_HOSTNAME=myapp.company.com

# Docker image (ghcr/dockerhub) hoặc build local (set build: . trong compose)
APP_IMAGE=ghcr.io/team/myapp:latest

# Port app listen TRONG container (oauth2-proxy forward upstream tới port này)
APP_PORT=3000

# ─── Zitadel (lấy từ ops admin) ────────────────────────────────────────
# Issuer URL = base URL của Zitadel auth server
ZITADEL_ISSUER_URL=https://auth.lab.local

# Hostname Zitadel (dùng cho extra_hosts khi lab self-signed, có thể giống ZITADEL_ISSUER_URL)
ZITADEL_HOSTNAME=auth.lab.local

# Optional: IP auth-vps để mapping extra_hosts khi không có DNS (LAB ONLY).
# Production có DNS thật → bỏ comment dòng dưới + xoá extra_hosts trong compose.
# ZITADEL_IP=192.168.122.54

# Client credentials từ Zitadel admin console khi tạo OIDC application
APP_CLIENT_ID=
APP_CLIENT_SECRET=

# ─── Cookie secret (auto-generate qua scripts/gen-secrets.sh) ─────────
# 32 chars, dùng để mã hoá session cookie của oauth2-proxy
APP_COOKIE_SECRET=

# ─── TLS mode ──────────────────────────────────────────────────────────
# lab: self-signed cert trong tls/   |   prod: Let's Encrypt qua Traefik certresolver
# Comment lại flag --ssl-insecure-skip-verify trong compose khi production.
TLS_MODE=lab
